# Shared infrastructure
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/monocore
REDIS_URL=redis://localhost:6379
DEFAULT_LOCALE=en

# API_* (server-only)
API_PORT=4000
API_TRUST_PROXY=false
SESSION_SECRET=replace-with-strong-secret-at-least-16-chars
SESSION_INACTIVITY_DAYS=30
SESSION_ABSOLUTE_DAYS=90
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://app.themonocore.com,https://staging-app.themonocore.com
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
CSRF_COOKIE_SAMESITE=lax

# WEB_PUBLIC_* (exposed to browser via Next public env)
WEB_PORT=3000
NEXT_PUBLIC_WEB_PUBLIC_API_URL=http://localhost:4000

# Seed
SEED_PLATFORM_ADMIN_EMAIL=admin@themonocore.com
SEED_PLATFORM_ADMIN_PASSWORD=ChangeMe123!
