generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ModuleStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
}

enum InstallationStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum FinanceCategoryType {
  INCOME
  EXPENSE
}

enum FinanceCounterpartyType {
  VENDOR
  CUSTOMER
  OTHER
}

enum FinanceAccountType {
  CASH
  BANK
  POS
  OTHER
}

enum FinanceDirection {
  INCOME
  EXPENSE
}

enum FinanceFrequency {
  WEEKLY
  MONTHLY
}

enum FinanceProfitCenterType {
  GENERAL
  SERVICE
  DEPARTMENT
  LOCATION
  EVENT
  OTHER
}

enum FinanceAllocationMethod {
  PERCENTAGE
}

enum FinanceInvoiceDirection {
  PAYABLE
  RECEIVABLE
}

enum FinanceInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOID
}

enum FinancePaymentDirection {
  OUTGOING
  INCOMING
}

enum FinanceBudgetDirection {
  INCOME
  EXPENSE
}

enum FinanceCashflowDirection {
  INFLOW
  OUTFLOW
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskScheduleType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum TaskAssigneeType {
  USER
  ROLE
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}
enum InventoryMovementType {
  IN
  OUT
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
}

enum InventoryMainStockArea {
  BAR
  KITCHEN
  OTHER
}

enum InventoryAttributeCategory {
  ALCOHOL
  SOFT
  KITCHEN
  OTHER
}

enum InventoryBaseUom {
  CL
  ML
  GRAM
  KG
  PIECE
}

enum InventoryPackageUom {
  BOTTLE
  PACK
  PIECE
}

enum InventoryStockCountSessionStatus {
  DRAFT
  POSTED
}

enum SalesOrderStatus {
  DRAFT
  POSTED
  VOID
}

enum ReservationStatus {
  BOOKED
  CONFIRMED
  SEATED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum SalaryType {
  FIXED
  HOURLY
}

enum PayrollGender {
  FEMALE
  MALE
  OTHER
  UNSPECIFIED
}

enum PayrollEmploymentStatus {
  DRAFT
  ACTIVE
  EXITED
}

enum PayrollInsuranceStatus {
  PENDING
  INSURED
  EXITED
}

enum PayrollPeriodStatus {
  DRAFT
  CALCULATED
  LOCKED
  POSTED
}

enum TipDistributionMethod {
  EQUAL
  HOURS_WEIGHTED
}

enum EmployeeDepartment {
  SERVICE
  BAR
  KITCHEN
  SUPPORT
  OTHER
}

enum TipWeekStatus {
  DRAFT
  CALCULATED
  LOCKED
  PAID
}

model User {
  id               String               @id @default(uuid())
  email            String               @unique
  fullName         String
  passwordHash     String
  locale           String               @default("en")
  isActive         Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  sessions         Session[]
  platformAccess   PlatformMembership[]
  companyMemberships CompanyMembership[]
  directoryEmployees CompanyEmployeeDirectory[]
  platformAuditLogs PlatformAuditLog[]  @relation("platform_actor")
  companyAuditLogs CompanyAuditLog[]    @relation("company_actor")
  platformInvites  PlatformInvite[]     @relation("platform_invite_creator")
  companyInvites   CompanyInvite[]      @relation("company_invite_creator")
  platformProfile  PlatformUserProfile? @relation("platform_user_profile_user")
  managedPlatformProfiles PlatformUserProfile[] @relation("platform_user_profile_manager")
  financeEntriesCreated FinanceEntry[]  @relation("finance_entry_creator")
  financeRecurringRulesCreated FinanceRecurringRule[] @relation("finance_recurring_rule_creator")
  financeAllocationBatchesCreated FinanceAllocationBatch[] @relation("finance_allocation_batch_creator")
  financeInvoicesCreated FinanceInvoice[] @relation("finance_invoice_creator")
  financePaymentsCreated FinancePayment[] @relation("finance_payment_creator")
  financeBudgetsCreated FinanceBudget[] @relation("finance_budget_creator")
  financeCashflowForecastItemsCreated FinanceCashflowForecastItem[] @relation("finance_cashflow_forecast_creator")
  taskTemplatesCreated TaskTemplate[] @relation("task_template_creator")
  taskTemplatesDefaultAssignee TaskTemplate[] @relation("task_template_default_assignee_user")
  taskInstancesCreated TaskInstance[] @relation("task_instance_creator")
  taskInstancesAssigned TaskInstance[] @relation("task_instance_assignee_user")
  taskCommentsAuthored TaskComment[] @relation("task_comment_author")
  inventoryMovementsCreated InventoryStockMovement[] @relation("inventory_movement_creator")
  inventoryStockCountsCreated InventoryStockCountSession[] @relation("inventory_stock_count_creator")
  inventoryItemSavedViewsCreated InventoryItemSavedView[]
  salesOrdersCreated SalesOrder[] @relation("sales_order_creator")
  reservationsCreated Reservation[] @relation("reservation_creator")
  tipAdvancesApproved TipAdvance[] @relation("tip_advance_approver")
}

model Session {
  id           String   @id @default(uuid())
  tokenHash    String   @unique
  userId       String
  ip           String?
  userAgent    String?
  expiresAt    DateTime
  absoluteExpiresAt DateTime
  createdAt    DateTime @default(now())
  lastActivityAt DateTime @default(now())
  revokedAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PlatformMembership {
  id         String             @id @default(uuid())
  userId     String
  invitedById String?
  isActive   Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles      PlatformUserRole[]

  @@unique([userId])
}

model PlatformRole {
  id           String                   @id @default(uuid())
  key          String                   @unique
  name         String
  description  String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  permissions  PlatformRolePermission[]
  users        PlatformUserRole[]
  invites      PlatformInvite[]
}

model PlatformPermission {
  id          String                   @id @default(uuid())
  key         String                   @unique
  description String?
  createdAt   DateTime                 @default(now())
  roles       PlatformRolePermission[]
}

model PlatformRolePermission {
  roleId        String
  permissionId  String
  role          PlatformRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    PlatformPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model PlatformUserRole {
  membershipId String
  roleId       String
  membership   PlatformMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role         PlatformRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([membershipId, roleId])
}

model Company {
  id             String               @id @default(uuid())
  name           String
  plan           String               @default("free")
  locale         String               @default("en")
  onboardingCompleted Boolean         @default(false)
  onboardingStep Int                  @default(1)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  memberships    CompanyMembership[]
  roles          CompanyRole[]
  departments    CompanyDepartment[]
  titles         CompanyTitle[]
  directoryEmployees CompanyEmployeeDirectory[]
  locations      Location[]
  modules        ModuleInstallation[]
  entitlements   CompanyEntitlement[]
  financeCategories FinanceCategory[]
  financeEntries FinanceEntry[]
  financeCounterparties FinanceCounterparty[]
  financeAccounts FinanceAccount[]
  financeRecurringRules FinanceRecurringRule[]
  financeProfitCenters FinanceProfitCenter[]
  financeAllocationRules FinanceAllocationRule[]
  financeAllocationBatches FinanceAllocationBatch[]
  financeInvoices FinanceInvoice[]
  financePayments FinancePayment[]
  financePaymentAllocations FinancePaymentAllocation[]
  financeBudgets FinanceBudget[]
  financeBudgetLines FinanceBudgetLine[]
  financeCashflowForecastItems FinanceCashflowForecastItem[]
  taskBoards TaskBoard[]
  taskTemplates TaskTemplate[]
  taskInstances TaskInstance[]
  taskComments TaskComment[]
  customers Customer[]
  customerTags CustomerTag[]
  customerTagLinks CustomerTagLink[]
  reservations Reservation[]
  inventoryWarehouses InventoryWarehouse[]
  inventoryItems InventoryItem[]
  inventorySuppliers InventorySupplier[]
  inventoryBrands InventoryBrand[]
  inventoryBrandSuppliers InventoryBrandSupplier[]
  inventoryStockMovements InventoryStockMovement[]
  inventoryStockCountSessions InventoryStockCountSession[]
  inventoryStockCountLines InventoryStockCountLine[]
  inventoryItemSavedViews InventoryItemSavedView[]
  salesProducts   SalesProduct[]
  recipes         Recipe[]
  recipeLines     RecipeLine[]
  salesOrders     SalesOrder[]
  salesOrderLines SalesOrderLine[]
  payrollEmployees PayrollEmployee[]
  payrollEmploymentRecords PayrollEmploymentRecord[]
  payrollCompensationProfiles PayrollCompensationProfile[]
  payrollCompensationMatrixRows PayrollCompensationMatrixRow[]
  employees       Employee[]
  workLogs        WorkLog[]
  payrollPeriods  PayrollPeriod[]
  payrollLines    PayrollLine[]
  tipPools        TipPool[]
  tipDistributions TipDistribution[]
  tipConfigurations TipConfiguration[]
  tipDepartmentRules TipDepartmentRule[]
  tipTitleRules      TipTitleRule[]
  tipWeeks         TipWeek[]
  tipDailyInputs   TipDailyInput[]
  tipAdvances      TipAdvance[]
  tipDepartmentOverrides TipDepartmentOverride[]
  tipWeekDistributions TipWeekDistribution[]
  auditLogs      CompanyAuditLog[]
  invites        CompanyInvite[]
}

model Location {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model CompanyMembership {
  id            String              @id @default(uuid())
  companyId     String
  userId        String
  invitedById   String?
  status        String              @default("active")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles         CompanyMemberRole[]

  @@unique([companyId, userId])
  @@index([userId])
}

model CompanyRole {
  id           String                  @id @default(uuid())
  companyId    String
  key          String
  name         String
  description  String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  company      Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissions  CompanyRolePermission[]
  members      CompanyMemberRole[]
  invites      CompanyInvite[]
  taskTemplatesDefault TaskTemplate[] @relation("task_template_default_assignee_role")
  taskInstancesAssigned TaskInstance[] @relation("task_instance_assignee_role")
  employees      Employee[]

  @@unique([companyId, key])
  @@index([companyId])
}

model CompanyPermission {
  id          String                   @id @default(uuid())
  key         String                   @unique
  description String?
  createdAt   DateTime                 @default(now())
  roles       CompanyRolePermission[]
}

model CompanyDepartment {
  id            String   @id @default(uuid())
  companyId     String
  name          String
  sortOrder     Int      @default(1000)
  parentId      String?
  tipDepartment EmployeeDepartment @default(OTHER)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent        CompanyDepartment? @relation("company_department_tree", fields: [parentId], references: [id], onDelete: SetNull)
  children      CompanyDepartment[] @relation("company_department_tree")
  titles        CompanyTitle[]
  tipRules      TipDepartmentRule[]
  tipTitleRules TipTitleRule[]

  @@index([companyId, isActive])
  @@index([companyId, parentId])
}

model CompanyTitle {
  id                  String   @id @default(uuid())
  companyId           String
  departmentId        String
  name                String
  sortOrder           Int      @default(1000)
  tipWeight           Decimal  @default(1) @db.Decimal(8, 2)
  isTipEligible       Boolean  @default(true)
  departmentAggregate Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department          CompanyDepartment @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  employees           CompanyEmployeeDirectory[]
  tipRules            TipTitleRule[]

  @@index([companyId, isActive])
  @@index([companyId, departmentId])
}

model CompanyEmployeeDirectory {
  id           String   @id @default(uuid())
  companyId    String
  firstName    String
  lastName     String
  userId       String?
  titleId      String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  title        CompanyTitle @relation(fields: [titleId], references: [id], onDelete: Restrict)
  tipAdvances  TipAdvance[]
  tipWeekDistributions TipWeekDistribution[]

  @@index([companyId, isActive])
  @@index([companyId, titleId])
  @@index([companyId, userId])
}

model CompanyRolePermission {
  roleId        String
  permissionId  String
  role          CompanyRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    CompanyPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model CompanyMemberRole {
  membershipId String
  roleId       String
  membership   CompanyMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role         CompanyRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([membershipId, roleId])
}

model Module {
  id            String               @id @default(uuid())
  key           String               @unique
  name          String
  description   String?
  version       String
  status        ModuleStatus
  dependencies  Json                 @default("{}")
  pricingMeta   Json                 @default("{}")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  installations ModuleInstallation[]
  entitlements  CompanyEntitlement[]
}

model ModuleInstallation {
  id          String              @id @default(uuid())
  companyId   String
  moduleKey   String
  status      InstallationStatus  @default(PENDING)
  config      Json                @default("{}")
  installedAt DateTime?
  createdAt   DateTime            @default(now())
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  module      Module              @relation(fields: [moduleKey], references: [key], onDelete: Cascade)

  @@unique([companyId, moduleKey])
}

model CompanyEntitlement {
  id        String   @id @default(uuid())
  companyId String
  moduleKey String
  limits    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  module    Module   @relation(fields: [moduleKey], references: [key], onDelete: Cascade)

  @@unique([companyId, moduleKey])
  @@index([companyId])
}

model SiteSetting {
  id           String   @id @default(uuid())
  key          String   @unique
  value        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LanguagePack {
  id         String   @id @default(uuid())
  locale     String
  namespace  String
  key        String
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([locale, namespace, key])
}

model PlatformAuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json     @default("{}")
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actor       User?    @relation("platform_actor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model CompanyAuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  companyId   String
  action      String
  entityType  String
  entityId    String?
  metadata    Json     @default("{}")
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actor       User?    @relation("company_actor", fields: [actorUserId], references: [id], onDelete: SetNull)
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

model PlatformDepartment {
  id        String   @id @default(uuid())
  name      String
  parentId  String?
  parent    PlatformDepartment? @relation("platform_department_tree", fields: [parentId], references: [id], onDelete: SetNull)
  children  PlatformDepartment[] @relation("platform_department_tree")
  profiles  PlatformUserProfile[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model PlatformTitle {
  id        String   @id @default(uuid())
  name      String   @unique
  profiles  PlatformUserProfile[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformUserProfile {
  userId         String @id
  departmentId   String?
  titleId        String?
  managerUserId  String?
  user           User   @relation("platform_user_profile_user", fields: [userId], references: [id], onDelete: Cascade)
  department     PlatformDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  title          PlatformTitle? @relation(fields: [titleId], references: [id], onDelete: SetNull)
  managerUser    User? @relation("platform_user_profile_manager", fields: [managerUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([departmentId])
  @@index([titleId])
  @@index([managerUserId])
}

model PlatformInvite {
  id              String    @id @default(uuid())
  email           String
  tokenHash       String    @unique
  roleId          String?
  expiresAt       DateTime
  usedAt          DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  createdByUserId String
  createdByUser   User      @relation("platform_invite_creator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  role            PlatformRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([createdAt])
}

model CompanyInvite {
  id              String    @id @default(uuid())
  companyId       String
  email           String
  tokenHash       String    @unique
  roleId          String?
  expiresAt       DateTime
  usedAt          DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  createdByUserId String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role            CompanyRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)
  createdByUser   User      @relation("company_invite_creator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([companyId, email])
  @@index([createdAt])
}

model FinanceCategory {
  id        String              @id @default(uuid())
  companyId String
  name      String
  type      FinanceCategoryType
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries   FinanceEntry[]
  recurringRules FinanceRecurringRule[]
  allocationRules FinanceAllocationRule[] @relation("allocation_rule_source_category")
  budgetLines FinanceBudgetLine[]

  @@unique([companyId, name])
  @@index([companyId, type])
}

model FinanceEntry {
  id              String    @id @default(uuid())
  companyId       String
  categoryId      String
  counterpartyId  String?
  accountId       String?
  profitCenterId  String?
  reference       String?
  isRecurringGenerated Boolean @default(false)
  recurringRuleId String?
  allocationBatchId String?
  isAllocationGenerated Boolean @default(false)
  invoiceId       String?
  paymentId       String?
  relatedDocumentType String?
  relatedDocumentId   String?
  amount          Decimal   @db.Decimal(14, 2)
  date            DateTime
  description     String?
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category        FinanceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  counterparty    FinanceCounterparty? @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)
  account         FinanceAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  profitCenter    FinanceProfitCenter? @relation(fields: [profitCenterId], references: [id], onDelete: SetNull)
  recurringRule   FinanceRecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)
  allocationBatch FinanceAllocationBatch? @relation("allocation_batch_entries", fields: [allocationBatchId], references: [id], onDelete: SetNull)
  sourceAllocationBatch FinanceAllocationBatch? @relation("allocation_batch_source_entry")
  sourceForAllocationRules FinanceAllocationRule[] @relation("allocation_rule_source_entry")
  invoice         FinanceInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  payment         FinancePayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdByUser   User      @relation("finance_entry_creator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([companyId, date])
  @@index([companyId, categoryId])
  @@index([companyId, counterpartyId])
  @@index([companyId, accountId])
  @@index([companyId, profitCenterId, date])
  @@index([companyId, invoiceId])
  @@index([companyId, paymentId])
  @@index([companyId, relatedDocumentType, relatedDocumentId])
}

model FinanceCounterparty {
  id        String   @id @default(uuid())
  companyId String
  type      FinanceCounterpartyType
  name      String
  taxId     String?
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries   FinanceEntry[]
  recurringRules FinanceRecurringRule[]
  invoices  FinanceInvoice[]
  payments  FinancePayment[]

  @@index([companyId, type])
  @@index([companyId, name])
}

model FinanceAccount {
  id        String   @id @default(uuid())
  companyId String
  type      FinanceAccountType
  name      String
  currency  String   @default("TRY")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries   FinanceEntry[]
  recurringRules FinanceRecurringRule[]
  payments  FinancePayment[]

  @@index([companyId, isActive])
  @@index([companyId, name])
}

model FinanceRecurringRule {
  id              String   @id @default(uuid())
  companyId       String
  name            String
  direction       FinanceDirection
  categoryId      String
  amount          Decimal  @db.Decimal(14, 2)
  startDate       DateTime
  frequency       FinanceFrequency
  dayOfMonth      Int?
  nextRunAt       DateTime
  isActive        Boolean  @default(true)
  counterpartyId  String?
  accountId       String?
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category        FinanceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  counterparty    FinanceCounterparty? @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)
  account         FinanceAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  createdByUser   User     @relation("finance_recurring_rule_creator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  generatedEntries FinanceEntry[]

  @@index([companyId, isActive, nextRunAt])
  @@index([companyId, frequency])
}

model FinanceProfitCenter {
  id        String   @id @default(uuid())
  companyId String
  name      String
  code      String?
  type      FinanceProfitCenterType
  parentId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent    FinanceProfitCenter? @relation("finance_profit_center_tree", fields: [parentId], references: [id], onDelete: SetNull)
  children  FinanceProfitCenter[] @relation("finance_profit_center_tree")
  entries   FinanceEntry[]
  salesOrders SalesOrder[]
  allocationTargets FinanceAllocationTarget[]
  budgetLines FinanceBudgetLine[]
  cashflowForecastItems FinanceCashflowForecastItem[]
  employees    Employee[]

  @@index([companyId, isActive])
  @@index([companyId, parentId])
  @@unique([companyId, name])
}

model FinanceAllocationRule {
  id              String   @id @default(uuid())
  companyId       String
  name            String
  sourceCategoryId String?
  sourceEntryId   String?
  allocationMethod FinanceAllocationMethod
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
