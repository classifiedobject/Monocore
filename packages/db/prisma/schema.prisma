  @@index([companyId, identityNumber])
}

model PayrollEmploymentRecord {
  id                           String                  @id @default(uuid())
  companyId                    String
  employeeId                   String
  departmentName               String?
  titleName                    String?
  arrivalDate                  DateTime
  accrualStartDate             DateTime
  sgkStartDate                 DateTime?
  sgkEntryDocumentPath         String?
  sgkEntryDocumentName         String?
  sgkEntryParsedIdentityNumber String?
  sgkEntryParsedFullName       String?
  sgkEntryParsedStartDate      DateTime?
  sgkEntryDocumentVerified     Boolean                 @default(false)
  exitDate                     DateTime?
  sgkExitDocumentPath          String?
  sgkExitDocumentName          String?
  sgkExitParsedIdentityNumber  String?
  sgkExitParsedFullName        String?
  sgkExitParsedExitDate        DateTime?
  sgkExitDocumentVerified      Boolean                 @default(false)
  status                       PayrollEmploymentStatus @default(DRAFT)
  insuranceStatus              PayrollInsuranceStatus  @default(PENDING)
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt
  company                      Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee                     PayrollEmployee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  compensationProfiles         PayrollCompensationProfile[]
  payrollLines                 PayrollLine[]

  @@index([companyId, employeeId])
  @@index([companyId, status])
  @@index([companyId, arrivalDate])
}

model PayrollCompensationProfile {
  id                    String   @id @default(uuid())
  companyId             String
  employmentRecordId    String
  matrixRowId           String?
  targetAccrualSalary   Decimal  @db.Decimal(14, 2)
  officialNetSalary     Decimal  @db.Decimal(14, 2)
  overtimeEligible      Boolean  @default(true)
  bonusEligible         Boolean  @default(true)
  handCashAllowed       Boolean  @default(true)
  effectiveFrom         DateTime
  effectiveTo           DateTime?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employmentRecord      PayrollEmploymentRecord     @relation(fields: [employmentRecordId], references: [id], onDelete: Cascade)
  matrixRow             PayrollCompensationMatrixRow? @relation(fields: [matrixRowId], references: [id], onDelete: SetNull)
  payrollLines          PayrollLine[]

  @@index([companyId, employmentRecordId])
  @@index([companyId, isActive])
  @@index([companyId, effectiveFrom])
}

model PayrollCompensationMatrixRow {
  id                    String   @id @default(uuid())
  companyId             String
  targetAccrualSalary   Decimal  @db.Decimal(14, 2)
  officialNetSalary     Decimal  @db.Decimal(14, 2)
  isActive              Boolean  @default(true)
  effectiveFrom         DateTime?
  effectiveTo           DateTime?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  compensationProfiles  PayrollCompensationProfile[]

  @@index([companyId, targetAccrualSalary])
  @@index([companyId, isActive])
}

model WorkLog {
  id          String   @id @default(uuid())
  companyId   String
  employeeId  String
  date        DateTime
  hoursWorked Decimal  @db.Decimal(8, 2)
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, employeeId, date])
  @@index([companyId, date])
}

model PayrollPeriod {
  id         String              @id @default(uuid())
  companyId  String
  startDate  DateTime
  endDate    DateTime
  status     PayrollPeriodStatus @default(DRAFT)
  totalGross Decimal             @default(0) @db.Decimal(14, 2)
  totalNet   Decimal             @default(0) @db.Decimal(14, 2)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  company    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines      PayrollLine[]

  @@index([companyId, status])
  @@index([companyId, startDate, endDate])
}

model PayrollLine {
  id                          String   @id @default(uuid())
  companyId                   String
  payrollPeriodId             String
  employeeId                  String
  employmentRecordId          String
  departmentName              String?
  titleName                   String?
  accrualDays                 Int      @default(0)
  officialDays                Int      @default(0)
  reportDays                  Int      @default(0)
  targetAccrualSalary         Decimal  @default(0) @db.Decimal(14, 2)
  officialNetSalary           Decimal  @default(0) @db.Decimal(14, 2)
  accrualPay                  Decimal  @default(0) @db.Decimal(14, 2)
  officialPay                 Decimal  @default(0) @db.Decimal(14, 2)
  calculatedBonus             Decimal  @default(0) @db.Decimal(14, 2)
  calculatedOvertime          Decimal  @default(0) @db.Decimal(14, 2)
  handCashRecommended         Decimal  @default(0) @db.Decimal(14, 2)
  handCashFinal               Decimal  @default(0) @db.Decimal(14, 2)
  bonusAdjustment             Decimal  @default(0) @db.Decimal(14, 2)
  totalPayable                Decimal  @default(0) @db.Decimal(14, 2)
  difference                  Decimal  @default(0) @db.Decimal(14, 2)
  controlOk                   Boolean  @default(false)
  sourceCompensationProfileId String?
  grossAmount                 Decimal  @default(0) @db.Decimal(14, 2)
  notes                       String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  company                     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payrollPeriod               PayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  employee                    PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  employmentRecord            PayrollEmploymentRecord @relation(fields: [employmentRecordId], references: [id], onDelete: Restrict)
  sourceCompensationProfile   PayrollCompensationProfile? @relation(fields: [sourceCompensationProfileId], references: [id], onDelete: SetNull)

  @@unique([payrollPeriodId, employmentRecordId])
  @@index([companyId, payrollPeriodId])
  @@index([companyId, employeeId])
}

model TipPool {
  id                 String   @id @default(uuid())
  companyId          String
  periodStart        DateTime
  periodEnd          DateTime
  totalTips          Decimal  @db.Decimal(14, 2)
  distributionMethod TipDistributionMethod
  createdAt          DateTime @default(now())
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  distributions      TipDistribution[]

  @@index([companyId, periodStart, periodEnd])
}

model TipDistribution {
  id         String   @id @default(uuid())
  companyId  String
  tipPoolId  String
  employeeId String
  amount     Decimal  @db.Decimal(14, 2)
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tipPool    TipPool  @relation(fields: [tipPoolId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([tipPoolId, employeeId])
  @@index([companyId, tipPoolId])
}

model TipConfiguration {
  id                       String   @id @default(uuid())
  companyId                String
  serviceRate              Decimal  @db.Decimal(6, 4)
  serviceTaxDeductionRate  Decimal  @default(0.4) @db.Decimal(6, 4)
  visaTaxDeductionRate     Decimal  @default(0.4) @db.Decimal(6, 4)
  defaultWastePoints       Decimal  @default(0) @db.Decimal(10, 2)
  allowDepartmentSubPool   Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  company                  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId])
}

model TipDepartmentRule {
  id               String   @id @default(uuid())
  companyId        String
  departmentId     String
  defaultTipWeight Decimal  @db.Decimal(10, 2)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department       CompanyDepartment @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  @@unique([companyId, departmentId])
  @@index([companyId, departmentId])
  @@index([companyId, isActive])
}

model TipTitleRule {
  id          String   @id @default(uuid())
  companyId   String
  titleId     String
  departmentId String
  tipWeight   Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title       CompanyTitle @relation(fields: [titleId], references: [id], onDelete: Restrict)
  department  CompanyDepartment @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  @@unique([companyId, titleId])
  @@index([companyId, departmentId])
  @@index([companyId, titleId])
  @@index([companyId, isActive])
}

model TipWeek {
  id               String   @id @default(uuid())
  companyId        String
  periodStart      DateTime
  periodEnd        DateTime
  serviceRateUsed  Decimal  @db.Decimal(6, 4)
  wastePointsUsed  Decimal  @default(0) @db.Decimal(10, 2)
  totalPoolGross   Decimal  @default(0) @db.Decimal(14, 2)
  totalPoolNet     Decimal  @default(0) @db.Decimal(14, 2)
  totalDistributed Decimal  @default(0) @db.Decimal(14, 2)
  status           TipWeekStatus @default(DRAFT)
  payableDate      DateTime?
  createdAt        DateTime @default(now())
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  advances         TipAdvance[]
  departmentOverrides TipDepartmentOverride[]
  distributions    TipWeekDistribution[]

  @@index([companyId, periodStart, periodEnd])
  @@index([companyId, status])
}

model TipDailyInput {
  id                      String   @id @default(uuid())
  companyId               String
  date                    DateTime
  grossRevenue            Decimal  @default(0) @db.Decimal(14, 2)
  discounts               Decimal  @default(0) @db.Decimal(14, 2)
  comps                   Decimal  @default(0) @db.Decimal(14, 2)
  wastageSales            Decimal  @default(0) @db.Decimal(14, 2)
  serviceRevenueCalculated Decimal @default(0) @db.Decimal(14, 2)
  netServiceRevenue       Decimal  @default(0) @db.Decimal(14, 2)
  netServiceFee           Decimal  @default(0) @db.Decimal(14, 2)
  cariAdisyonTotal        Decimal  @default(0) @db.Decimal(14, 2)
  cashTips                Decimal  @default(0) @db.Decimal(14, 2)
  visaTipsGross           Decimal  @default(0) @db.Decimal(14, 2)
  visaTipsNet             Decimal  @default(0) @db.Decimal(14, 2)
  expenseAdjustments      Decimal  @default(0) @db.Decimal(14, 2)
  createdAt               DateTime @default(now())
  company                 Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
  @@index([companyId, date])
}

model TipAdvance {
  id               String   @id @default(uuid())
  companyId        String
  employeeId       String?
  directoryEmployeeId String?
  tipWeekId        String
  amount           Decimal  @db.Decimal(14, 2)
  approvedByUserId String
  createdAt        DateTime @default(now())
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee         Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  directoryEmployee CompanyEmployeeDirectory? @relation(fields: [directoryEmployeeId], references: [id], onDelete: SetNull)
  tipWeek          TipWeek  @relation(fields: [tipWeekId], references: [id], onDelete: Cascade)
  approvedBy       User     @relation("tip_advance_approver", fields: [approvedByUserId], references: [id], onDelete: Restrict)

  @@index([companyId, tipWeekId])
  @@index([companyId, employeeId])
  @@index([companyId, directoryEmployeeId])
}

model TipDepartmentOverride {
  id             String   @id @default(uuid())
  companyId      String
  tipWeekId      String
  department     EmployeeDepartment
  overrideWeight Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tipWeek        TipWeek  @relation(fields: [tipWeekId], references: [id], onDelete: Cascade)

  @@unique([tipWeekId, department])
  @@index([companyId, tipWeekId])
}

model TipWeekDistribution {
  id          String   @id @default(uuid())
  companyId   String
  tipWeekId   String
  employeeId  String?
  directoryEmployeeId String?
  tipWeightUsed Decimal @db.Decimal(10, 2)
  grossShare  Decimal  @db.Decimal(14, 2)
  advanceDeducted Decimal @default(0) @db.Decimal(14, 2)
  netShare    Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tipWeek     TipWeek  @relation(fields: [tipWeekId], references: [id], onDelete: Cascade)
  employee    Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  directoryEmployee CompanyEmployeeDirectory? @relation(fields: [directoryEmployeeId], references: [id], onDelete: SetNull)

  @@unique([tipWeekId, employeeId])
  @@unique([tipWeekId, directoryEmployeeId])
  @@index([companyId, tipWeekId])
  @@index([companyId, employeeId])
  @@index([companyId, directoryEmployeeId])
}
